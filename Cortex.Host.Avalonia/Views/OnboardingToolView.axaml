<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Cortex.Host.Avalonia.Views.OnboardingToolView">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="12">
      <TextBlock FontSize="22" FontWeight="SemiBold" Text="Choose defaults for the desktop shell" />

      <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,18,0,0">
        <StackPanel Spacing="8">
          <TextBlock FontWeight="SemiBold" Text="Workspace Root" />
          <TextBox Name="OnboardingWorkspaceRootTextBox" Text="{Binding Onboarding.SelectedWorkspaceRootPath}" />
          <Button HorizontalAlignment="Left" Click="BrowseOnboardingWorkspaceRoot_OnClick">Browse Folder</Button>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="8">
          <TextBlock FontWeight="SemiBold" Text="Profile" />
          <ComboBox Name="OnboardingProfileComboBox"
                    ItemsSource="{Binding OnboardingProfiles}"
                    SelectedItem="{Binding SelectedOnboardingProfile}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Foreground="#9CA8BC" Text="{Binding Onboarding.SelectedProfileId}" />

          <TextBlock FontWeight="SemiBold" Text="Layout" />
          <ComboBox Name="OnboardingLayoutComboBox"
                    ItemsSource="{Binding OnboardingLayouts}"
                    SelectedItem="{Binding SelectedOnboardingLayout}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Foreground="#9CA8BC" Text="{Binding Onboarding.SelectedLayoutPresetId}" />
        </StackPanel>
      </Grid>

      <StackPanel Grid.Row="2" Margin="0,18,0,0" Spacing="8">
        <TextBlock FontWeight="SemiBold" Text="Theme" />
        <ListBox Name="OnboardingThemeListBox"
                 Height="180"
                 ItemsSource="{Binding ThemeOptions}"
                 SelectedItem="{Binding SelectedOnboardingTheme}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,8" Padding="10" CornerRadius="12" BorderBrush="#314056" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Border Width="36" Height="36" CornerRadius="10" Background="{Binding AccentColor}" />
                  <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                    <TextBlock Foreground="#9CA8BC" Text="{Binding Description}" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </StackPanel>

      <Border Grid.Row="3" Margin="0,18,0,0" Padding="12" CornerRadius="12" Background="#151924" BorderBrush="#314056" BorderThickness="1">
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold" Text="Current flow" />
          <ItemsControl ItemsSource="{Binding OnboardingFlow.Steps}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="0,0,0,6">
                  <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  <TextBlock Foreground="#9CA8BC" Text="{Binding Description}" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="4" Margin="0,18,0,0" Orientation="Horizontal" Spacing="12">
        <Button Click="ApplyOnboarding_OnClick" Content="Apply Onboarding" />
        <TextBlock VerticalAlignment="Center" Foreground="#9CA8BC" Text="{Binding ThemePreviewSummary}" TextWrapping="Wrap" />
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
