<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Cortex.Host.Avalonia.Views.SearchToolView">
  <Grid RowDefinitions="Auto,Auto,*" Margin="12">
    <StackPanel Spacing="4">
      <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SearchTitle}" />
      <TextBlock Foreground="#9CA8BC" Text="{Binding SearchScopeCaption}" />
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,12,0,0" Orientation="Horizontal" Spacing="8">
      <TextBox Width="320" Name="SearchQueryTextBox" Text="{Binding WorkbenchSearchQuery}" />
      <Button Click="RunSearch_OnClick" Content="Search" />
      <TextBlock VerticalAlignment="Center" Foreground="#9CA8BC" Text="{Binding SearchMatchCountSummary}" />
      <TextBlock VerticalAlignment="Center" Foreground="#9CA8BC" Text="{Binding SearchStatusSummary}" TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="2" Margin="0,12,0,0" Padding="8" CornerRadius="8" Background="#101521" BorderBrush="#314056" BorderThickness="1">
      <ListBox Name="SearchResultsListBox"
               ItemsSource="{Binding SearchMatches}"
               SelectionChanged="SearchResultsListBox_OnSelectionChanged">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,6">
              <TextBlock Text="{Binding DisplayText}" />
              <TextBlock Foreground="#9CA8BC" Text="{Binding DocumentPath}" TextWrapping="Wrap" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </Grid>
</UserControl>
