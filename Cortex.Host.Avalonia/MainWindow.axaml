<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:Dock.Avalonia.Controls;assembly=Dock.Avalonia"
        x:Class="Cortex.Host.Avalonia.MainWindow"
        Width="1440"
        Height="920"
        Title="Cortex Desktop Host">
  <Grid RowDefinitions="Auto,*,Auto" Margin="18">
    <Border Grid.Row="0"
            Padding="18"
            CornerRadius="18"
            BorderBrush="#314056"
            BorderThickness="1"
            Background="#1D2230">
      <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12">
        <StackPanel Spacing="6">
          <TextBlock FontSize="26" FontWeight="SemiBold" Text="Cortex Desktop Host" />
          <TextBlock Foreground="#9CA8BC"
                     Text="Avalonia shell rendering the current Cortex workbench through Dock-owned structure." />
          <TextBlock Foreground="#9CA8BC" Text="{Binding LayoutModeSummary}" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
          <Button Click="SaveLayout_OnClick" Content="Save Layout" />
          <Button Click="ResetLayout_OnClick" Content="Reset Layout" />
        </StackPanel>

        <ItemsControl Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding SurfaceToggles}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" ItemWidth="120" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Content="{Binding Title}"
                        IsChecked="{Binding IsVisible}"
                        IsEnabled="{Binding CanHide}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Margin="0,18,0,18"
            CornerRadius="18"
            BorderBrush="#314056"
            BorderThickness="1"
            Background="#151924">
      <dock:DockControl Name="WorkbenchDockControl"
                        InitializeFactory="False"
                        InitializeLayout="False" />
    </Border>

    <Border Grid.Row="2" Padding="12" CornerRadius="12" Background="#1D2230" BorderBrush="#314056" BorderThickness="1">
      <TextBlock Text="{Binding ShellStatusMessage}" />
    </Border>
  </Grid>
</Window>
