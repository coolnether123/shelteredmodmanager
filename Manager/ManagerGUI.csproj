:: Decompiler Tool &amp; Dependencies
if exist "%25BASE%25Decompiler\Decompiler.csproj" dotnet build "%25BASE%25Decompiler\Decompiler.csproj" -c %25CONFIG%25
if exist "%25BASE%25Cortex.Tabby.Server\Cortex.Tabby.Server.csproj" dotnet build "%25BASE%25Cortex.Tabby.Server\Cortex.Tabby.Server.csproj" -c %25CONFIG%25
if exist "%25BASE%25Cortex.Roslyn.Worker\Cortex.Roslyn.Worker.csproj" dotnet build "%25BASE%25Cortex.Roslyn.Worker\Cortex.Roslyn.Worker.csproj" -c %25CONFIG%25
if exist "%25BASE%25Dist\SMM\bin\roslyn\Cortex.Roslyn.Worker.dll" copy /y "%25BASE%25Dist\SMM\bin\roslyn\Cortex.Roslyn.Worker.dll" "%25DECOMPILER_DIR%25\"
