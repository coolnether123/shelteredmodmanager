if exist "%25BASE%25libs\winhttp.dll" copy /y "%25BASE%25libs\winhttp.dll" "%25BASE%25Dist\"

if exist "%25BASE%25PluginConsole\bin\%25CONFIG%25\PluginConsole.dll" copy /y "%25BASE%25PluginConsole\bin\%25CONFIG%25\PluginConsole.dll" "%25MODS_DIR%25\PluginConsole\Assemblies\"
